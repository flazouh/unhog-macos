# Local signing configuration for scripts/release-app.sh.
#
# Copy this file to scripts/release.local.env and fill in your own values.
# scripts/release.local.env is git-ignored and must never be committed.

# Full "Developer ID Application" identity string, exactly as printed by:
#   security find-identity -v -p codesigning
export UNHOG_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Your Apple Developer team identifier (the value in parentheses above).
export UNHOG_TEAM_ID="TEAMID"

# The notarytool keychain profile you created once with:
#   xcrun notarytool store-credentials "<profile>" --apple-id "<id>" --team-id "TEAMID"
export UNHOG_NOTARY_PROFILE="your-notary-profile"
